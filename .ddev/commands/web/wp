#!/usr/bin/env bash

## Description: Run WP-CLI commands
## Usage: wp [flags] [args]
## Example: ddev wp plugin list

set -euo pipefail

DOCROOT="/var/www/html"
if [ -n "${DDEV_DOCROOT:-}" ] && [ "${DDEV_DOCROOT}" != "." ]; then
    WP_PATH="${DOCROOT}/${DDEV_DOCROOT}"
else
    WP_PATH="${DOCROOT}"
fi

wp --path="${WP_PATH}" "$@"
